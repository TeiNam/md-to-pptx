# AWS Bedrock 자격 증명
# .env 파일이 있으면 우선 사용하고, 없으면 AWS SSO / ~/.aws/credentials 등 boto3 기본 체인을 따릅니다.

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1

# Bedrock 모델 ID (선택)
# 미설정 시 기본값: global.anthropic.claude-opus-4-6-v1
# 기본 모델 실패 시 fallback: global.anthropic.claude-opus-4-5-20251101-v1:0
# BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-6-v1

# 폰트 설정 (선택)
# 미설정 시 기본값: 나눔고딕
# DEFAULT_FONT=나눔고딕
# DEFAULT_MONO_FONT=D2Coding
